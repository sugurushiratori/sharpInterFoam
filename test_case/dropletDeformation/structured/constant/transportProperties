FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      transportProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

phases (water air);

water
{
    transportModel  Newtonian;
    nu              1e-2;
    rho             1;
}

air
{
    transportModel  Newtonian;
    nu              1.0e-2;
    rho             1e-3;
}

sigma           1;

